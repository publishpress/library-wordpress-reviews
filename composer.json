{
  "name": "publishpress/wordpress-reviews",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "description": "Library for showing a five-star review banner.",
  "keywords": [
    "reviews",
    "review",
    "wordpress plugin"
  ],
  "homepage": "http://publishpress.com/",
  "authors": [
    {
      "name": "PublishPress",
      "email": "help@publishpress.com"
    },
    {
      "name": "Daniel Iser",
      "homepage": "https://github.com/danieliser/WP-Product-In-Dash-Review-Requests"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "files": [
      "ReviewsController.php"
    ]
  },
  "require": {
    "php": ">=7.2"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/publishpress/library-publishpress-translator.git"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^8.5 || ^9.0",
    "brain/monkey": "^2.6",
    "phpcompatibility/php-compatibility": "^9.3",
    "wp-coding-standards/wpcs": "^3",
    "squizlabs/php_codesniffer": "^3.8",
    "overtrue/phplint": "^9.1",
    "friendsofphp/php-cs-fixer": "^3.49",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "automattic/vipwpcs": "^3",
    "publishpress/publishpress-phpcs-standards": "dev-main",
    "publishpress/translations": "dev-development"
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text",
    "check": [
      "@check:php",
      "@check:lint",
      "@check:cs"
    ],
    "check:php": [
      "@check:php-7.2",
      "@check:php-7.4",
      "@check:php-8.0",
      "@check:php-8.1",
      "@check:php-8.2",
      "@check:php-8.3",
      "@check:php-8.4"
    ],
    "check:php-7.4": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 7.4",
    "check:php-8.0": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.0",
    "check:php-8.1": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.1",
    "check:php-8.2": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.2",
    "check:php-8.3": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.3",
    "check:php-8.4": "phpcs --standard=.phpcs-php-compatibility.xml --runtime-set testVersion 8.4",
    "check:lint": "phplint --no-cache",
    "check:cs": "phpcs",
    "check:stan": "phpstan",
        "translate": [
      "vendor/bin/publishpress-translate translate"
    ],
    "translate:dry-run": [
      "vendor/bin/publishpress-translate translate --dry-run"
    ],
    "translate:download": [
      "vendor/bin/publishpress-translate download"
    ],
    "translate:upload": [
      "vendor/bin/publishpress-translate upload"
    ],
    "translate:force": [
      "vendor/bin/publishpress-translate translate --force"
    ],
    "translate:force-custom": [
      "vendor/bin/publishpress-translate translate --force --custom"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
